<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>PriceHawk</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;font-size:13px;color:#c9d1d9;background:#0d1117;width:360px;min-height:300px;padding:16px}
h1{font-size:16px;color:#f0c040;margin-bottom:4px}
.subtitle{font-size:11px;color:#8b949e;margin-bottom:16px}
.section-title{font-size:11px;font-weight:600;color:#8b949e;text-transform:uppercase;margin-bottom:8px}
.product{padding:10px 12px;background:#161b22;border:1px solid #30363d;border-radius:8px;margin-bottom:6px;display:flex;align-items:center;gap:10px;transition:border-color 0.15s}
.product:hover{border-color:#f0c040}
.product-img{width:40px;height:40px;border-radius:4px;object-fit:cover;background:#21262d;flex-shrink:0}
.product-info{flex:1;min-width:0}
.product-name{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.product-platform{font-size:10px;color:#8b949e}
.product-price{text-align:right;flex-shrink:0}
.current-price{font-size:16px;font-weight:700;color:#f0c040}
.price-change{font-size:11px}
.price-change.up{color:#3fb950}
.price-change.down{color:#f85149}
.product-actions{display:flex;gap:4px;margin-left:8px}
.product-btn{font-size:10px;padding:2px 6px;border:1px solid #30363d;border-radius:4px;background:transparent;color:#8b949e;cursor:pointer}
.product-btn:hover{color:#f85149;border-color:#f85149}
.alert-item{padding:8px 12px;margin-bottom:4px;background:#161b22;border-left:3px solid #3fb950;border-radius:4px;font-size:12px}
.alert-item .alert-time{font-size:10px;color:#8b949e;margin-top:2px}
.empty{padding:32px 0;text-align:center;color:#484f58}
.empty .emoji{font-size:36px;margin-bottom:8px}
.footer{padding-top:12px;margin-top:12px;border-top:1px solid #21262d;display:flex;justify-content:space-between;align-items:center}
.footer a{color:#58a6ff;text-decoration:none;font-size:11px}
</style>
</head>
<body>
<h1>🦅 PriceHawk</h1>
<p class="subtitle">浏览商品时自动追踪价格</p>

<div class="section-title" style="margin-bottom:8px">📊 监控列表</div>
<div id="product-list"></div>

<div class="section-title" style="margin-top:16px;margin-bottom:8px">🔔 降价提醒</div>
<div id="alert-list"></div>

<div class="footer">
  <a href="#" id="clear-alerts">清除提醒</a>
  <a href="#" id="btn-settings">⚙️ 设置</a>
</div>

<script src="popup.js"></script>
</body>
</html>
