<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>PriceHawk · 设置</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;font-size:14px;color:#c9d1d9;background:#0d1117;max-width:500px;margin:40px auto;padding:0 20px}
h1{font-size:22px;color:#f0c040;margin-bottom:24px}
.card{background:#161b22;border:1px solid #30363d;border-radius:8px;padding:20px;margin-bottom:20px}
.card h2{font-size:15px;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #30363d}
.field{margin-bottom:16px}
.field label{display:block;font-weight:600;margin-bottom:4px;font-size:13px}
.field .hint{font-size:12px;color:#8b949e;margin-bottom:6px}
.field input,.field select{width:100%;padding:8px 12px;font-size:13px;border:1px solid #30363d;border-radius:6px;background:#0d1117;color:#c9d1d9}
.field input:focus,.field select:focus{outline:none;border-color:#f0c040}
.checkbox{display:flex;align-items:center;gap:8px}
.checkbox input{width:auto}
.btn{padding:8px 20px;font-size:14px;font-weight:600;border-radius:6px;cursor:pointer;border:none;background:#f0c040;color:#0d1117}
.btn:hover{background:#ffd700}
.btn:disabled{opacity:.65}
#status{margin-left:12px;font-size:13px;color:#3fb950;display:none}
</style>
</head>
<body>
<h1>🦅 PriceHawk 设置</h1>

<div class="card">
  <h2>提醒设置</h2>
  <div class="field">
    <label>降价提醒阈值 (%)</label>
    <div class="hint">价格降幅超过此比例时通知</div>
    <input type="number" id="alert-threshold" min="1" max="50" step="1" value="5">
  </div>
  <div class="field">
    <label>价格检查频率 (小时)</label>
    <select id="refresh-hours">
      <option value="1">1 小时</option>
      <option value="3">3 小时</option>
      <option value="6" selected>6 小时</option>
      <option value="12">12 小时</option>
      <option value="24">24 小时</option>
    </select>
  </div>
  <div class="field checkbox">
    <input type="checkbox" id="notify-on-drop" checked>
    <label>启用降价通知</label>
  </div>
</div>

<div class="card">
  <button class="btn" id="save">保存设置</button>
  <span id="status"></span>
</div>

<script src="options.js"></script>
</body>
</html>
